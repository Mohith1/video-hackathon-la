# ── AWS Credentials (required for S3 uploads + Pegasus pipeline) ──────────────
# Get from: AWS Console → IAM → Security Credentials → Temporary credentials
# (for workshop: Event Engine → Team Dashboard → Get CLI Credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=719573866669

# ── TwelveLabs via Bedrock (bearer token — from hackathon workshop) ────────────
# Required for Pegasus + Marengo calls via Bedrock InvokeModel API
AWS_BEARER_TOKEN_BEDROCK=bedrock-api-key-...

# ── S3 ─────────────────────────────────────────────────────────────────────────
S3_BUCKET=twelvelabs-bedrock-workshop-workshopbucket-pta7wtkszqkf
S3_VECTORS_BUCKET=twelvelabs-bedrock-workshop-workshopbucket-pta7wtkszqkf

# ── DynamoDB ───────────────────────────────────────────────────────────────────
DYNAMODB_TABLE=segmentiq-videos

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production
# Set to your Vercel frontend URL (comma-separated for multiple)
CORS_ORIGINS=https://your-app.vercel.app
